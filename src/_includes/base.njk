<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}</title>
{% if description %}<meta name="description" content="{{ description }}" />{% endif %}
<meta name="author" content="Constantin Chopin" />
<meta name="color-scheme" content="dark" />
{% if ogType %}
<meta property="og:type" content="{{ ogType }}" />
<meta property="og:title" content="{{ ogTitle or title }}" />
{% if ogDesc %}<meta property="og:description" content="{{ ogDesc }}" />{% endif %}
{% if ogUrl %}<meta property="og:url" content="{{ ogUrl }}" />{% endif %}
{% endif %}
<link rel="icon" href="/favicon.svg" />
<link rel="stylesheet" href="/styles.css" />
<script>if (window.self !== window.top) document.documentElement.classList.add('embedded');</script>
{% if headExtra %}{{ headExtra | safe }}{% endif %}
</head>
<body class="{{ bodyClass }}">
{{ content | safe }}
</body>
</html>
